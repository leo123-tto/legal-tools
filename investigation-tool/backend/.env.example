# 企查查 CLI 配置
# 如有多个 Key，用逗号分隔，程序会自动轮换（Bearer token 格式）
# QCC_AUTHORIZATIONS=Bearer token1,Bearer token2

# 元典 API Key（多个用逗号分隔，积分不足时自动切换）
YUANDIAN_API_KEYS=your_yuandian_api_key_here

# 报告生成 Provider (lm_studio | hermes | cloud | claude_code)
REPORT_PROVIDER=lm_studio

# LM Studio (默认)
LM_STUDIO_BASE_URL=http://127.0.0.1:1234/v1
REPORT_MODEL=gemma-4-26b-a4b-it

# Hermes (需要启动 hermes gateway)
HERMES_BASE_URL=http://127.0.0.1:8642/v1
HERMES_API_KEY=your_hermes_api_key_here

# Cloud (中转站)
CLOUD_API_BASE_URL=https://your-proxy.example/v1
CLOUD_API_KEY=your_cloud_api_key_here
REPORT_MODEL=your_model_name

# 访问控制 (多个用逗号分隔)
ALLOWED_API_KEYS=your-access-key-here
